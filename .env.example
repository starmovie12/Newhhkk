# GitHub Folder Uploader - Environment Variables Example
# Copy this file to .env.local and fill in your values if needed

# Note: This app primarily uses localStorage for credentials
# These env vars are optional and mainly for documentation

# Your GitHub Personal Access Token (optional - can be entered in UI)
# Get it from: https://github.com/settings/tokens
# NEXT_PUBLIC_GITHUB_TOKEN=your_token_here

# Your GitHub username (optional - can be entered in UI)
# NEXT_PUBLIC_GITHUB_USERNAME=your_username
